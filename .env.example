# Environment Configuration for WikiService
# Copy this file to .env and fill in your actual values

# ==================== Database ====================
DB_PASSWORD=weknora_secret_db_password

# ==================== Neo4j ====================
NEO4J_PASSWORD=weknora_secret_neo4j_password

# ==================== Embedding Model (Configurable per business) ====================
# Provider: siliconflow, jina, openai, or custom
EMBEDDING_PROVIDER=siliconflow

# SiliconFlow BGE-M3 (recommended for Chinese)
# Get API key: https://cloud.siliconflow.cn
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your_siliconflow_api_key_here
EMBEDDING_MODEL=BAAI/bge-m3

# Alternative: Jina AI
# EMBEDDING_API_BASE=https://api.jina.ai/v1
# EMBEDDING_API_KEY=your_jina_api_key_here
# EMBEDDING_MODEL=jina-embeddings-v3

# ==================== WeKnora ====================
# Knowledge Base ID - will be created on first ingestion
WEKNORA_KB_ID=kb_default

# ==================== Optional: MinIO/OSS ====================
# OSS_PROVIDER=minio
# OSS_ENDPOINT=play.min.io
# OSS_ACCESS_KEY=your_access_key
# OSS_SECRET_KEY=your_secret_key
# OSS_BUCKET=weknora
