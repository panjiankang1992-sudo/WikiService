# WikiService 环境变量配置

# ===== 服务配置 =====
PORT=23100                                    # 服务端口（23100-23109）
STORAGE_PATH=./data                          # 数据存储目录（开发用 ./data，生产用 /opt/wikiservice/data）
LOG_DIR=./logs                               # 日志目录

# ===== Embedding 模型（离线部署必选 Ollama）=====
EMBEDDING_PROVIDER=ollama                   # 向量模型来源: ollama | deepseek | keyword
EMBEDDING_MODEL=nomic-embed-text            # Ollama 模型名（离线用 nomic-embed-text）
EMBEDDING_BASE_URL=http://localhost:11434   # Ollama 服务地址

# ===== DeepSeek API（当前版本仅作占位，无需真实 Key）=====
DEEPSEEK_API_KEY=offline-placeholder         # 占位字符串即可（未来 LLM 评分功能需要真实 Key）

# ===== LLM 配置（当前版本未使用）=====
MODEL_NAME=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
