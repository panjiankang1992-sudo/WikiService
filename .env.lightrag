# WikiService LightRAG - 环境配置
# Copy this file to .env.lightrag and fill in your values

# ==================== DeepSeek API (必需) ====================
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# API Base URL (usually no need to change)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model configuration
MODEL_NAME=deepseek-chat
EMBEDDING_MODEL=deepseek-embedding

# ==================== Storage ====================
# Persistent data storage path inside container
STORAGE_PATH=/data/lightrag

# ==================== Optional ====================
# GitHub token for higher API rate limits (optional)
# GITHUB_TOKEN=
